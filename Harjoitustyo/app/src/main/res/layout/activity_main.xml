<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <EditText
        android:id="@+id/searchMunicipality"
        android:layout_width="252dp"
        android:layout_height="64dp"
        android:layout_marginTop="68dp"
        android:ems="10"
        android:hint="Hae kuntaa nimellä..."
        android:inputType="text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titleText" />

    <Button
        android:id="@+id/searchMunicipalityButton"
        android:layout_width="176dp"
        android:layout_height="66dp"
        android:layout_marginTop="36dp"
        android:backgroundTint="#609FA4"
        android:onClick="switchToInformation"
        android:text="Hae tiedot"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/searchMunicipality" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Kuntasovellus"
        android:textSize="30sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewList"
        android:layout_width="223dp"
        android:layout_height="47dp"
        android:layout_marginTop="52dp"
        android:text="Viimeksi haetut kunnat"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/searchMunicipalityButton" />

    <Button
        android:id="@+id/municipality1"
        android:layout_width="224dp"
        android:layout_height="40dp"
        android:backgroundTint="#609FA4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewList" />

    <Button
        android:id="@+id/municipality2"
        android:layout_width="224dp"
        android:layout_height="40dp"
        android:backgroundTint="#609FA4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/municipality1" />

    <Button
        android:id="@+id/municipality3"
        android:layout_width="224dp"
        android:layout_height="40dp"
        android:backgroundTint="#609FA4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/municipality2" />

    <Button
        android:id="@+id/municipality4"
        android:layout_width="224dp"
        android:layout_height="40dp"
        android:backgroundTint="#609FA4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/municipality3" />

    <Button
        android:id="@+id/municipality5"
        android:layout_width="224dp"
        android:layout_height="40dp"
        android:backgroundTint="#609FA4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.502"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/municipality4"
        app:layout_constraintVertical_bias="0.0" />

</androidx.constraintlayout.widget.ConstraintLayout>

